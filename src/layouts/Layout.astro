---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Anastacia Frost — Designer & Developer',
  description = 'Graphic designer, web developer, and UI/UX person. Ten years of design systems, brand work, and making the boring parts of software feel like they deserve care. Based in Michigan.',
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type" content="website" />
  <meta name="twitter:card" content="summary" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Yeseva+One&family=Inter:wght@400;600&family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />
</head>
<body>
  <div id="boot" class="boot">
    <div class="boot-stack">
      <span>booting anastacia.frost</span>
      <span>loading personality.json</span>
      <span>calibrating chaos levels</span>
      <span>brewing boba</span>
    </div>
  </div>

  <!-- Custom cursor elements — activated by EasterEggs on desktop -->
  <div class="cursor" id="cursor"></div>
  <div class="cursor-dot" id="cursor-dot"></div>

  <slot />

  <!--
    ┌──────────────────────────────────────────────┐
    │  hello, you found the source. nice.          │
    │  open the console for more.                  │
    │  — A.F.                                      │
    └──────────────────────────────────────────────┘
  -->

  <script is:inline>
    setTimeout(() => {
      const boot = document.getElementById('boot');
      if (boot) boot.classList.add('gone');
      document.dispatchEvent(new CustomEvent('bootcomplete'));
    }, 1400);
    setTimeout(() => {
      const boot = document.getElementById('boot');
      if (boot) boot.remove();
    }, 2200);
  </script>
</body>
</html>
